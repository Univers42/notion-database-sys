{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "types": [
      "react",
      "react-dom"
    ]
  },
  "include": [
    "render.tsx"
  ]
}
