{
  "name": "notion-database-sys",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:playground": "vite --port=3001 --host=0.0.0.0",
    "dev:api": "turbo run dev --filter=@notion-db/api",
    "dev:all": "turbo run dev --parallel",
    "seed:playground": "node scripts/seed-playground.mjs",
    "build": "turbo run build",
    "build:types": "turbo run build --filter=@notion-db/types",
    "build:core": "turbo run build --filter=@notion-db/core",
    "build:api": "turbo run build --filter=@notion-db/api",
    "preview": "vite preview",
    "clean": "rm -rf dist packages/*/dist",
    "lint": "tsc --noEmit && eslint src/ --max-warnings=0",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.13.0",
    "mongodb": "^7.1.1",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "autoprefixer": "^10.4.21",
    "cmake-js": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "node-addon-api": "^8.7.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "protobufjs"
    ]
  }
}
