# === DBMS Configuration ===

# PostgreSQL (Docker init — creates default DB)
# If you override POSTGRES_PORT in your local `.env`, update the host-side
# DATABASE_URL and SRC_DATABASE_URL below to use the same port.
POSTGRES_USER=notion_user
POSTGRES_PASSWORD=notion_pass
POSTGRES_DB=notion_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://notion_user:notion_pass@localhost:5432/notion_db

# MongoDB (Docker init — creates default DB)
MONGO_USER=notion_user
MONGO_PASSWORD=notion_pass
MONGO_DB=notion_db
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_URI=mongodb://notion_user:notion_pass@localhost:27017/notion_db?authSource=admin

# ── Per-context DB names (isolation) ─────────────────────────────────────────
SRC_POSTGRES_DB=notion_src_db
SRC_MONGO_DB=notion_src_db
SRC_DATABASE_URL=postgresql://notion_user:notion_pass@localhost:5432/notion_src_db
SRC_MONGO_URI=mongodb://notion_user:notion_pass@localhost:27017/notion_src_db?authSource=admin

PLAYGROUND_MONGO_DB=notion_playground_db
PLAYGROUND_MONGO_URI=mongodb://notion_user:notion_pass@localhost:27017/notion_playground_db?authSource=admin

# File-based DB paths (relative to project root — src only)
JSON_DB_PATH=./src/store/dbms/json
CSV_DB_PATH=./src/store/dbms/csv

# Active DB source for the app (json | csv | mongodb | postgresql)
ACTIVE_DB_SOURCE=json

# ── App services / ports ──────────────────────────────────────────────────────
SRC_PORT=3000
PLAYGROUND_PORT=3001
API_HOST=0.0.0.0
API_PORT=4000
CONTRACT_SERVER_HOST=0.0.0.0
CONTRACT_SERVER_PORT=4100
CONTRACT_SERVER_AUTH=disabled
CONTRACT_SERVER_JWT_SECRET=dev-contract-secret
LOG_LEVEL=info
SYNC_INDEXES=true
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m

# ── Auxiliary Docker services ─────────────────────────────────────────────────
REDIS_PORT=6379
SONAR_PORT=9000
SONARQUBE_IMAGE=sonarqube:26.3.0.120487-community

# ── Playground (Vite exposes VITE_* vars to the browser) ──────────────────────
VITE_API_URL=http://localhost:4000
