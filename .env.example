# -----------------------------------------------------------------------------
# Notion database system example runtime
# Managed by apps/baas/scripts/vault-env.mjs.
# Copy to the matching .env file only for local development; Vault is the source of truth after seeding.
# -----------------------------------------------------------------------------

# REQUIRED: Required. The service will not boot, authenticate, or bridge correctly without these keys.
# Required. Runtime configuration key for this service. If omitted: startup, auth, or bridge flow can fail.
ACTIVE_DB_SOURCE=json

# Required. Runtime configuration key for this service. If omitted: startup, auth, or bridge flow can fail.
API_HOST=0.0.0.0

# Required. Local port for Docker or development tooling. If omitted: startup, auth, or bridge flow can fail.
API_PORT=3000

# Required. Secret or token used for local authentication. If omitted: startup, auth, or bridge flow can fail.
JWT_EXPIRES_IN=replace-with-jwt-expires-in

# Required. Signing secret shared by GoTrue, PostgREST, Kong, and generated JWTs. If omitted: startup, auth, or bridge flow can fail.
JWT_SECRET=replace-with-jwt-secret

# RECOMMENDED: Recommended. Defaults keep local Docker usable, but set these to make routing, email, and integrations explicit.
# Recommended. Internal Postgres URL used by BaaS services. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
DATABASE_URL=postgres://postgres:replace-with-postgres-secret@postgres:5432/postgres

# Recommended. MongoDB setting used by optional document/database adapters. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
MONGO_DB=replace-with-mongo-db

# Recommended. MongoDB setting used by optional document/database adapters. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
MONGO_HOST=localhost

# Recommended. MongoDB setting used by optional document/database adapters. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
MONGO_PASSWORD=replace-with-mongo-password

# Recommended. MongoDB setting used by optional document/database adapters. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
MONGO_PORT=3000

# Recommended. MongoDB setting used by optional document/database adapters. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
MONGO_URI=postgres://postgres:replace-with-postgres-secret@postgres:5432/postgres

# Recommended. MongoDB setting used by optional document/database adapters. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
MONGO_USER=replace-with-mongo-user

# Recommended. Postgres connection setting for the local Docker database. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
POSTGRES_DB=postgres

# Recommended. Postgres connection setting for the local Docker database. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
POSTGRES_HOST=postgres

# Recommended. Postgres connection setting for the local Docker database. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
POSTGRES_PASSWORD=replace-with-postgres-password

# Recommended. Postgres connection setting for the local Docker database. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
POSTGRES_PORT=5432

# Recommended. Postgres connection setting for the local Docker database. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
POSTGRES_USER=postgres

# Recommended. Browser-exposed configuration. Never put private secrets in this key. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
VITE_API_URL=http://localhost:4000

# OPTIONAL: Optional. Leave empty to disable the integration and gain a smaller local attack surface.
# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
CONTRACT_SERVER_AUTH=

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
CONTRACT_SERVER_HOST=localhost

# Optional. Secret or token used for local authentication. If omitted: the related integration is disabled, reducing local secret sprawl.
CONTRACT_SERVER_JWT_SECRET=

# Optional. Local port for Docker or development tooling. If omitted: the related integration is disabled, reducing local secret sprawl.
CONTRACT_SERVER_PORT=3000

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
CSV_DB_PATH=

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
JSON_DB_PATH=

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
LOG_LEVEL=

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
PLAYGROUND_MONGO_DB=

# Optional. Service URL used for local routing. If omitted: the related integration is disabled, reducing local secret sprawl.
PLAYGROUND_MONGO_URI=postgres://postgres:replace-with-postgres-secret@postgres:5432/postgres

# Optional. Local port for Docker or development tooling. If omitted: the related integration is disabled, reducing local secret sprawl.
PLAYGROUND_PORT=3000

# Optional. Local port for Docker or development tooling. If omitted: the related integration is disabled, reducing local secret sprawl.
REDIS_PORT=3000

# Optional. Local port for Docker or development tooling. If omitted: the related integration is disabled, reducing local secret sprawl.
SONAR_PORT=3000

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
SONARQUBE_IMAGE=

# Optional. Service URL used for local routing. If omitted: the related integration is disabled, reducing local secret sprawl.
SRC_DATABASE_URL=http://localhost:3000

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
SRC_MONGO_DB=

# Optional. Service URL used for local routing. If omitted: the related integration is disabled, reducing local secret sprawl.
SRC_MONGO_URI=postgres://postgres:replace-with-postgres-secret@postgres:5432/postgres

# Optional. Local port for Docker or development tooling. If omitted: the related integration is disabled, reducing local secret sprawl.
SRC_PORT=3000

