{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "MONGO_URI",
    "MONGO_HOST",
    "MONGO_PORT",
    "MONGO_USER",
    "MONGO_PASSWORD",
    "MONGO_DB",
    "REDIS_URL",
    "REDIS_HOST",
    "REDIS_PORT",
    "POSTGRES_HOST",
    "POSTGRES_PORT",
    "POSTGRES_USER",
    "POSTGRES_PASSWORD",
    "POSTGRES_DB",
    "API_PORT",
    "API_HOST",
    "JWT_SECRET",
    "JWT_EXPIRES_IN",
    "LOG_LEVEL",
    "NODE_ENV",
    "SYNC_INDEXES"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^build"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ]
    }
  }
}
